rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isWhitelistedCouple() {
      return request.auth != null && (
        request.auth.token.email == 'haritmishra123@gmail.com' ||
        request.auth.token.email == 'shethameera@gmail.com'
      );
    }

    match /{document=**} {
      allow read, write: if false;
    }

    match /letters/{letterId} {
      allow read, write: if isWhitelistedCouple();
    }
    match /dinners/{dinnerId} {
      allow read, write: if isWhitelistedCouple();
    }
    match /gratitudes/{gratitudeId} {
      allow read, write: if isWhitelistedCouple();
    }
    match /voiceNotes/{voiceId} {
      allow read, write: if isWhitelistedCouple();
    }
    match /memories/{memoryId} {
      allow read, write: if isWhitelistedCouple();
    }
    match /users/{userId} {
      allow read, write: if isWhitelistedCouple();
    }
  }
}
