rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isWhitelistedCouple() {
      return request.auth != null && (
        request.auth.token.email == 'haritmishra123@gmail.com' ||
        request.auth.token.email == 'shethameera@gmail.com'
      );
    }

    match /{allPaths=**} {
      allow read: if isWhitelistedCouple();
      allow write: if isWhitelistedCouple() &&
        request.resource.size < 10 * 1024 * 1024;
    }
  }
}
