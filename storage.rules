rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    function isWhitelistedCouple() {
      return request.auth != null && (
        request.auth.token.email == 'harit@sunrise.app' || 
        request.auth.token.email == 'ameera@sunrise.app'
      );
    }

    match /{allPaths=**} {
      // Separate read rule (request.resource is NOT defined on read operations)
      allow read: if isWhitelistedCouple();

      // Separate write rule (request.resource IS defined on write operations)
      allow write: if isWhitelistedCouple() &&
        request.resource.size < 10 * 1024 * 1024; // 10MB max file size limit
    }
  }
}
